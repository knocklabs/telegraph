{
  "name": "@telegraph/vite-config",
  "version": "0.0.20",
  "author": "@knocklabs",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist/*",
    "README.md"
  ],
  "prettier": "@telegraph/prettier-config",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "yarn clean && tsc -b",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier \"src/**/*.{js,ts,tsx}\" --write",
    "format:check": "prettier \"src/**/*.{js,ts,tsx}\" --check"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "vite": "^8.1.2",
    "vite-plugin-dts": "^5.0.1"
  },
  "devDependencies": {
    "@knocklabs/eslint-config": "^0.0.5",
    "@knocklabs/typescript-config": "^0.0.2",
    "@telegraph/prettier-config": "workspace:^",
    "eslint": "^10.4.0",
    "typescript": "^6.0.2"
  },
  "repository": "https://github.com/knocklabs/telegraph/tree/main/packages/vite-config"
}
