{
  "name": "@knocklabs/telegraph",
  "version": "0.0.1",
  "description": "The design system at Knock",
  "main": "index.js",
  "repository": "https://github.com/knocklabs/telegraph",
  "author": "@knocklabs",
  "license": "MIT",
  "private": true,
  "packageManager": "yarn@4.9.1",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "generate:package": "moon generate package",
    "dev:packages": "turbo dev --filter=\"./packages/*\" --concurrency=100",
    "dev:examples": "turbo dev:examples --filter=\"./examples/*\" --concurrency=100",
    "build:packages": "turbo build --filter=\"./packages/*\"",
    "build:config": "turbo build --filter=\"./packages/*-config\"",
    "test": "vitest run --config=./vitest/config.mts",
    "test:watch": "vitest watch --config=./vitest/config.mts",
    "lint": "turbo lint --filter=\"./packages/**\" --filter=\"!@telegraph/prettier-config\"",
    "format": "turbo format",
    "format:check": "turbo format:check",
    "dev:storybook": "storybook dev --port 3005",
    "build:storybook": "storybook build",
    "release": "yarn release:publish && yarn changeset tag",
    "release:publish": "yarn workspaces foreach -Rpt --no-private --from '@telegraph/*' npm publish --access public --tolerate-republish",
    "postinstall": "manypkg check",
    "prepare": "husky",
    "manypkg:check": "manypkg check",
    "manypkg:fix": "manypkg fix"
  },
  "workspaces": [
    "packages/*",
    "examples/*",
    "apps/*"
  ],
  "manypkg": {
    "defaultBranch": "main",
    "ignoredRules": [
      "INTERNAL_MISMATCH"
    ]
  },
  "resolutions": {
    "parse5": "^7.2.1"
  },
  "devDependencies": {
    "@actions/core": "^3.0.0",
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@github-ui/storybook-addon-performance-panel": "^1.1.4",
    "@knocklabs/eslint-config": "^0.0.5",
    "@manypkg/cli": "^0.25.1",
    "@moonrepo/cli": "^2.1.1",
    "@storybook/addon-links": "^10.3.1",
    "@storybook/addon-onboarding": "^10.3.1",
    "@storybook/addon-themes": "^10.3.4",
    "@storybook/icons": "^2.0.1",
    "@storybook/react": "^10.3.4",
    "@storybook/react-vite": "^10.3.1",
    "@testing-library/dom": "^10.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "4.1.0",
    "eslint": "^10.2.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-turbo": "^2.9.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "postcss-import": "^16.1.1",
    "postcss-import-ext-glob": "^2.1.1",
    "prettier": "^3.8.1",
    "prop-types": "^15.8.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "storybook": "^10.3.1",
    "storybook-addon-render-modes": "^0.0.11",
    "turbo": "^2.9.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "4.1.0",
    "vitest-axe": "0.1.0"
  }
}
